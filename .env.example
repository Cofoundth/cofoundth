# Supabase — get these from https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# New "publishable" key format (sb_publishable_...). Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Server-only secret key — never expose to the browser
# Used for transactional email notifications (reading auth.users emails server-side)
SUPABASE_SECRET_KEY=sb_secret_...

# Email — Resend (transactional notifications: interest received, mutual match, new message)
RESEND_API_KEY=re_...
# Optional. Default: "CoFound.th <onboarding@resend.dev>". Switch to your verified domain.
# RESEND_FROM_EMAIL=CoFound.th <noreply@fahbok.com>

# Public site URL used in email links (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
